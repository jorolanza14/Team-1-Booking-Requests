    "/api/parishes/search": {
      "get": {
        "summary": "Search parishes by name or location",
        "tags": ["Parishes"],
        "description": "Public endpoint - no authentication required",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search term for name or address"
          },
          {
            "name": "services",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by services offered (comma-separated)"
          }
        ],
        "responses": {
          "200": {
