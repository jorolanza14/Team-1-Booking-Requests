    "/api/parish-settings/{parishId}/slot-settings": {
      "get": {
        "summary": "Get parish slot settings",
        "tags": ["Parish Settings"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "parishId", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {
            "description": "Parish slot settings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "settings": {"type": "array", "items": {"$ref": "#/components/schemas/ParishSlotSetting"}}
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create or update parish slot setting",
        "tags": ["Parish Settings"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "parishId", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["serviceType"],
                "properties": {
                  "serviceType": {"type": "string", "enum": ["baptism", "wedding", "confirmation", "eucharist", "reconciliation", "anointing_sick", "funeral_mass", "mass_intention"]},
                  "dailyLimit": {"type": "integer"},
                  "weeklyLimit": {"type": "integer"},
                  "timeSlots": {"type": "array", "items": {"$ref": "#/components/schemas/TimeSlot"}},
                  "cutoffTime": {"type": "string", "format": "time"},
                  "minAdvanceDays": {"type": "integer", "default": 1},
                  "maxAdvanceDays": {"type": "integer", "default": 90},
                  "isActive": {"type": "boolean", "default": true}
                }
              }
            }
          }
        },
        "responses": {"200": {"description": "Parish slot setting saved successfully"}}
      }
    },
    "/api/parish-settings/{parishId}/blackout-dates": {
      "get": {
        "summary": "Get parish blackout dates",
        "tags": ["Parish Settings"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "parishId", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "serviceType", "in": "query", "schema": {"type": "string"}},
          {"name": "startDate", "in": "query", "schema": {"type": "string", "format": "date"}},
          {"name": "endDate", "in": "query", "schema": {"type": "string", "format": "date"}}
        ],
        "responses": {"200": {"description": "List of blackout dates"}}
      },
      "post": {
        "summary": "Create blackout date",
        "tags": ["Parish Settings"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "parishId", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["date"],
                "properties": {
                  "date": {"type": "string", "format": "date"},
                  "serviceType": {"type": "string"},
                  "reason": {"type": "string"},
                  "isRecurring": {"type": "boolean", "default": false},
                  "recurrencePattern": {"type": "string", "enum": ["yearly", "monthly", "weekly"]}
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "Blackout date created successfully"}}
      }
    },
    "/api/sacramental-records": {
      "get": {
        "summary": "Search sacramental records",
        "tags": ["Sacramental Records"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20}},
          {"name": "parishId", "in": "query", "schema": {"type": "integer"}},
          {"name": "sacramentType", "in": "query", "schema": {"type": "string", "enum": ["baptism", "confirmation", "eucharist", "wedding"]}},
          {"name": "personName", "in": "query", "schema": {"type": "string"}},
          {"name": "fatherName", "in": "query", "schema": {"type": "string"}},
          {"name": "motherName", "in": "query", "schema": {"type": "string"}},
          {"name": "year", "in": "query", "schema": {"type": "integer"}},
          {"name": "startDate", "in": "query", "schema": {"type": "string", "format": "date"}},
          {"name": "endDate", "in": "query", "schema": {"type": "string", "format": "date"}}
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "records": {"type": "array", "items": {"$ref": "#/components/schemas/SacramentalRecord"}},
                    "pagination": {"$ref": "#/components/schemas/Pagination"}
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create sacramental record (digitization)",
        "tags": ["Sacramental Records"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["parishId", "sacramentType", "personName", "sacramentDate"],
                "properties": {
                  "parishId": {"type": "integer"},
                  "sacramentType": {"type": "string", "enum": ["baptism", "confirmation", "eucharist", "wedding"]},
                  "personName": {"type": "string"},
                  "dateOfBirth": {"type": "string", "format": "date"},
                  "fatherName": {"type": "string"},
                  "motherName": {"type": "string"},
                  "sacramentDate": {"type": "string", "format": "date"},
                  "officiatingPriest": {"type": "string"},
                  "certificateNumber": {"type": "string"},
                  "scannedCopy": {"type": "string", "format": "binary"}
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "Sacramental record created successfully"}}
      }
    },
    "/api/payments": {
      "get": {
        "summary": "Get all payments",
        "tags": ["Payments"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20}},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["pending", "paid", "partial", "refunded", "cancelled"]}},
          {"name": "parishId", "in": "query", "schema": {"type": "integer"}},
          {"name": "bookingType", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "List of payments"}}
      },
      "post": {
        "summary": "Create payment",
        "tags": ["Payments"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["bookingType", "bookingId"],
                "properties": {
                  "bookingType": {"type": "string"},
                  "bookingId": {"type": "integer"},
                  "amount": {"type": "number", "default": 0},
                  "donationAmount": {"type": "number", "default": 0},
                  "paymentMethod": {"type": "string", "enum": ["cash", "gcash", "paymaya", "bank_transfer", "check", "credit_card"]},
                  "proofOfPayment": {"type": "string", "format": "binary"}
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "Payment created successfully"}}
      }
    }
  },
  "components": {
    "schemas": {
      "BaptismBooking": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "parishId": {"type": "integer"},
          "userId": {"type": "integer"},
          "childFullName": {"type": "string"},
          "dateOfBirth": {"type": "string", "format": "date"},
          "fatherName": {"type": "string"},
          "motherName": {"type": "string"},
          "contactEmail": {"type": "string", "format": "email"},
          "contactPhone": {"type": "string"},
          "preferredDate": {"type": "string", "format": "date"},
          "preferredTimeSlot": {"type": "string"},
          "preferredPriest": {"type": "string"},
          "additionalNotes": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "approved", "declined", "completed", "rescheduled"]},
          "adminNotes": {"type": "string"},
          "approvedBy": {"type": "integer"},
          "approvedAt": {"type": "string", "format": "date-time"},
          "godparents": {"type": "array", "items": {"$ref": "#/components/schemas/Godparent"}},
          "documents": {"type": "array", "items": {"$ref": "#/components/schemas/BookingDocument"}}
        }
      },
      "WeddingBooking": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "parishId": {"type": "integer"},
          "userId": {"type": "integer"},
          "groomFullName": {"type": "string"},
          "brideFullName": {"type": "string"},
          "contactEmail": {"type": "string", "format": "email"},
          "contactPhone": {"type": "string"},
          "preferredDate": {"type": "string", "format": "date"},
          "preferredTimeSlot": {"type": "string"},
          "seminarSchedule": {"type": "string", "format": "date-time"},
          "preferredPriest": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "approved", "declined", "completed", "rescheduled"]},
          "godparents": {"type": "array", "items": {"$ref": "#/components/schemas/Godparent"}}
        }
      },
      "ConfirmationBooking": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "confirmandName": {"type": "string"},
          "fatherName": {"type": "string"},
          "motherName": {"type": "string"},
          "preferredDate": {"type": "string", "format": "date"},
          "preferredTimeSlot": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "approved", "declined", "completed", "rescheduled"]},
          "godparents": {"type": "array", "items": {"$ref": "#/components/schemas/Godparent"}}
        }
      },
      "Godparent": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "bookingType": {"type": "string", "enum": ["baptism", "wedding", "confirmation"]},
          "bookingId": {"type": "integer"},
          "fullName": {"type": "string"},
          "contactEmail": {"type": "string", "format": "email"},
          "contactPhone": {"type": "string"},
          "parishAffiliation": {"type": "string"}
        }
      },
      "GodparentInput": {
        "type": "object",
        "properties": {
          "fullName": {"type": "string", "example": "Pedro Santos"},
          "contactEmail": {"type": "string", "format": "email"},
          "contactPhone": {"type": "string"},
          "parishAffiliation": {"type": "string"},
          "confirmationCertificateNumber": {"type": "string"}
        }
      },
      "BookingDocument": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "bookingType": {"type": "string"},
          "bookingId": {"type": "integer"},
          "documentType": {"type": "string", "enum": ["birth_certificate", "baptismal_certificate", "confirmation_certificate", "cenomar", "death_certificate", "id_card", "proof_of_payment", "other"]},
          "fileName": {"type": "string"},
          "fileUrl": {"type": "string"},
          "isVerified": {"type": "boolean"}
        }
      },
      "ParishSlotSetting": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "parishId": {"type": "integer"},
          "serviceType": {"type": "string"},
          "dailyLimit": {"type": "integer"},
          "weeklyLimit": {"type": "integer"},
          "timeSlots": {"type": "array", "items": {"$ref": "#/components/schemas/TimeSlot"}},
          "cutoffTime": {"type": "string", "format": "time"},
          "minAdvanceDays": {"type": "integer"},
          "maxAdvanceDays": {"type": "integer"},
          "isActive": {"type": "boolean"}
        }
      },
      "TimeSlot": {
        "type": "object",
        "properties": {
          "start": {"type": "string", "example": "09:00"},
          "end": {"type": "string", "example": "10:00"},
          "capacity": {"type": "integer", "example": 5},
          "available": {"type": "boolean"}
        }
      },
      "BlackoutDate": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "parishId": {"type": "integer"},
          "serviceType": {"type": "string"},
          "date": {"type": "string", "format": "date"},
          "reason": {"type": "string"},
          "isRecurring": {"type": "boolean"},
          "recurrencePattern": {"type": "string", "enum": ["yearly", "monthly", "weekly"]}
        }
      },
      "SacramentalRecord": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "parishId": {"type": "integer"},
          "sacramentType": {"type": "string"},
          "personName": {"type": "string"},
          "dateOfBirth": {"type": "string", "format": "date"},
          "fatherName": {"type": "string"},
          "motherName": {"type": "string"},
          "sacramentDate": {"type": "string", "format": "date"},
          "officiatingPriest": {"type": "string"},
          "certificateNumber": {"type": "string"},
          "year": {"type": "integer"},
          "hasScannedCopy": {"type": "boolean"}
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "bookingType": {"type": "string"},
          "bookingId": {"type": "integer"},
          "parishId": {"type": "integer"},
          "userId": {"type": "integer"},
          "amount": {"type": "number"},
          "donationAmount": {"type": "number"},
          "totalAmount": {"type": "number"},
          "paymentMethod": {"type": "string", "enum": ["cash", "gcash", "paymaya", "bank_transfer", "check", "credit_card"]},
          "status": {"type": "string", "enum": ["pending", "paid", "partial", "refunded", "cancelled"]},
          "proofOfPaymentUrl": {"type": "string"}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "email": {"type": "string", "format": "email"},
          "firstName": {"type": "string"},
          "lastName": {"type": "string"},
          "middleName": {"type": "string"},
          "phone": {"type": "string"},
          "role": {"type": "string", "enum": ["parishioner", "parish_staff", "priest", "diocese_staff", "parish_admin", "diocese_admin"]},
          "assignedParishId": {"type": "integer", "nullable": true},
          "isActive": {"type": "boolean"}
        }
      },
      "Parish": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "address": {"type": "string"},
          "contactEmail": {"type": "string", "format": "email"},
          "contactPhone": {"type": "string"},
          "contactPerson": {"type": "string"},
          "schedule": {"type": "object"},
          "servicesOffered": {"type": "array", "items": {"type": "string"}},
          "sacramentSettings": {"type": "object"},
          "bookingSettings": {"type": "object"},
          "isActive": {"type": "boolean"}
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "total": {"type": "integer"},
          "page": {"type": "integer"},
          "limit": {"type": "integer"},
          "pages": {"type": "integer"}
        }
      },
      "Booking": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "bookingType": {
            "type": "string",
            "enum": ["baptism", "wedding", "confirmation", "mass-intention"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "approved", "rejected", "completed", "cancelled"]
          },
          "userId": {
            "type": "integer"
          },
          "parishId": {
            "type": "integer"
          },
          "preferredDate": {
            "type": "string",
            "format": "date"
          },
          "notes": {
            "type": "string"
          },
          "adminNotes": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SystemConfiguration": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Configuration ID"
          },
          "parishId": {
            "type": "integer",
            "description": "Associated parish ID"
          },
          "configType": {
            "type": "string",
            "enum": ["booking", "mass_intention", "general"],
            "description": "Type of configuration"
          },
          "dailyLimit": {
            "type": "integer",
            "description": "Daily booking/intention limit",
            "nullable": true
          },
          "weeklyLimit": {
            "type": "integer",
            "description": "Weekly booking/intention limit",
            "nullable": true
          },
          "monthlyLimit": {
            "type": "integer",
            "description": "Monthly booking/intention limit",
            "nullable": true
          },
          "timeSlots": {
            "type": "array",
            "description": "Available time slots for bookings",
            "items": {
              "type": "object",
              "properties": {
                "startTime": {
                  "type": "string",
                  "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
                },
                "endTime": {
                  "type": "string",
                  "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
                },
                "capacity": {
                  "type": "integer"
                }
              }
            },
            "nullable": true
          },
          "blackoutDates": {
            "type": "array",
            "description": "Dates when bookings are not allowed",
            "items": {
              "type": "string",
              "format": "date"
            },
            "nullable": true
          },
          "massSchedules": {
            "type": "array",
            "description": "Mass schedule configurations",
            "items": {
              "type": "object",
              "properties": {
                "dayOfWeek": {
                  "type": "string",
                  "enum": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]
                },
                "times": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
                  }
                }
              }
            },
            "nullable": true
          },
          "bookingCutoffDays": {
            "type": "integer",
            "description": "Number of days before event when bookings close",
            "nullable": true
          },
          "maxAdvanceBookingDays": {
            "type": "integer",
            "description": "Maximum days in advance for booking",
            "nullable": true
          },
          "cutoffTime": {
            "type": "string",
            "description": "Daily cutoff time for same-day bookings",
            "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$",
            "nullable": true
          },
          "autoApprove": {
            "type": "boolean",
            "description": "Whether to auto-approve bookings/intentions",
            "nullable": true
          },
          "requiredDocuments": {
            "type": "array",
            "description": "List of required documents for bookings",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "maxGodparents": {
            "type": "integer",
            "description": "Maximum number of godparents allowed",
            "nullable": true
          },
          "instructions": {
            "type": "string",
            "description": "Special instructions for users",
            "nullable": true
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether this configuration is active",
            "default": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DashboardStats": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "object",
            "properties": {
              "totalUsers": {
                "type": "integer",
                "example": 150
              },
              "totalParishes": {
                "type": "integer",
                "example": 25
              },
              "totalBookings": {
                "type": "integer",
                "example": 500
              },
              "totalMassIntentions": {
                "type": "integer",
                "example": 200
              },
              "pendingApprovals": {
                "type": "integer",
                "example": 15
              },
              "activeParishes": {
                "type": "integer",
                "example": 23
              }
            }
          },
          "recentBookings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Booking"
            },
            "description": "List of recent bookings (last 10)"
          },
          "bookingsByStatus": {
            "type": "object",
            "properties": {
              "pending": {
                "type": "integer",
                "example": 25
              },
              "approved": {
                "type": "integer",
                "example": 150
              },
              "rejected": {
                "type": "integer",
                "example": 10
              },
              "completed": {
                "type": "integer",
                "example": 300
              },
              "cancelled": {
                "type": "integer",
                "example": 15
              }
            }
          },
          "bookingsByType": {
            "type": "object",
            "properties": {
              "baptism": {
                "type": "integer",
                "example": 100
              },
              "wedding": {
                "type": "integer",
                "example": 50
              },
              "confirmation": {
                "type": "integer",
                "example": 75
              },
              "mass-intention": {
                "type": "integer",
                "example": 275
              }
            }
          }
        }
      },
      "AdminUserResponse": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "AdminParishResponse": {
        "type": "object",
        "properties": {
          "parishes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Parish"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "AdminBookingResponse": {
        "type": "object",
        "properties": {
          "bookings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Booking"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "tags": [
      {
        "name": "Authentication",
        "description": "User authentication and authorization endpoints"
      },
      {
        "name": "Parishes",
        "description": "Parish management endpoints"
      },
      {
        "name": "Mass Intentions",
        "description": "Mass intention booking and management endpoints"
      },
      {
        "name": "Mass Schedules",
        "description": "Mass schedule management endpoints"
      },
      {
        "name": "Admin",
        "description": "Administrative endpoints for system management including dashboard, user management, parish management, system configuration, and booking oversight"
      }
    ]
  }
}
