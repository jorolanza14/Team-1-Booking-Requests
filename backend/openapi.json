    "/api/mass-schedules": {
      "get": {
        "summary": "Get all mass schedules",
        "tags": ["Mass Schedules"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Only authorized personnel (parish_admin, parish_staff, diocese_staff, diocese_admin) can access",
        "parameters": [
          {
            "name": "parishId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by parish ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of mass schedules",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "massSchedules": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MassSchedule"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new mass schedule",
        "tags": ["Mass Schedules"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Only authorized personnel (parish_admin, parish_staff, diocese_staff, diocese_admin) can create",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["parishId", "dayOfWeek", "startTime", "endTime"],
                "properties": {
                  "parishId": {
                    "type": "integer",
                    "example": 1
                  },
                  "dayOfWeek": {
                    "type": "string",
                    "enum": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
                    "example": "Sunday"
                  },
                  "startTime": {
                    "type": "string",
                    "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$",
                    "example": "08:00"
                  },
                  "endTime": {
                    "type": "string",
                    "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$",
                    "example": "09:00"
                  },
                  "priestId": {
                    "type": "integer",
