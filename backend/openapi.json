    },
    "/api/mass-intentions": {
      "get": {
        "summary": "Get all mass intentions",
        "tags": ["Mass Intentions"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of items per page"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["For the Dead", "Thanksgiving", "Special Intention"]
            },
            "description": "Filter by intention type"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["pending", "approved", "declined", "completed"]
            },
            "description": "Filter by status"
          },
          {
            "name": "parishId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by parish ID"
          },
          {
            "name": "startDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Filter by start date (YYYY-MM-DD)"
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Filter by end date (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of mass intentions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "massIntentions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MassIntention"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new mass intention",
        "tags": ["Mass Intentions"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type", "intentionDetails", "donorName", "parishId", "massSchedule"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["For the Dead", "Thanksgiving", "Special Intention"],
                    "example": "For the Dead"
                  },
                  "intentionDetails": {
                    "type": "string",
                    "example": "For the souls of departed family members"
                  },
                  "donorName": {
                    "type": "string",
                    "example": "John Doe"
                  },
                  "parishId": {
                    "type": "integer",
                    "example": 1
                  },
                  "massSchedule": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2023-12-25T08:00:00.000Z"
                  },
                  "preferredPriest": {
                    "type": "string",
                    "example": "Fr. John Smith"
                  },
                  "notes": {
                    "type": "string",
                    "example": "Special request for morning mass"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Mass intention created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Mass intention created successfully"
                    },
                    "massIntention": {
                      "$ref": "#/components/schemas/MassIntention"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
