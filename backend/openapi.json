{
  "openapi": "3.0.0",
  "info": {
    "title": "Diocese of Kalookan API",
    "version": "1.0.0",
    "description": "Backend API for the Diocese Sacramental Management System"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "firstName", "lastName"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "john.doe@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "example": "password123"
                  },
                  "firstName": {
                    "type": "string",
                    "example": "John"
                  },
                  "lastName": {
                    "type": "string",
                    "example": "Doe"
                  },
                  "phone": {
                    "type": "string",
                    "example": "09123456789"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "User registered successfully"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    },
                    "accessToken": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "refreshToken": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "john.doe@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Login successful"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    },
                    "accessToken": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "refreshToken": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/parishes": {
      "get": {
        "summary": "Get all parishes",
        "tags": ["Parishes"],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["true", "false"]
            },
            "description": "Filter by active status (default: true)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of parishes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Parish"
                      }
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new parish",
        "tags": ["Parishes"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Only diocese_staff and diocese_admin can create parishes",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "address"],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Our Lady of Peace Parish"
                  },
                  "address": {
                    "type": "string",
                    "example": "123 Main Street, Kalookan City"
                  },
                  "contactEmail": {
                    "type": "string",
                    "format": "email",
                    "example": "info@olpparish.org"
                  },
                  "contactPhone": {
                    "type": "string",
                    "example": "+639123456789"
                  },
                  "schedule": {
                    "type": "object",
                    "example": {
                      "sunday": "7:00 AM, 9:00 AM, 11:00 AM",
                      "weekdays": "6:00 AM"
                    }
                  },
                  "servicesOffered": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": ["baptism", "wedding", "confirmation", "mass-intention"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Parish created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Parish"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/parishes/{id}": {
      "get": {
        "summary": "Get a specific parish by ID",
        "tags": ["Parishes"],
        "description": "Public endpoint - no authentication required",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Parish ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Parish details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Parish"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update a parish",
        "tags": ["Parishes"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Diocese staff can update any parish; parish_admin can update only their assigned parish",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Parish ID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Our Lady of Peace Parish"
                  },
                  "address": {
                    "type": "string",
                    "example": "123 Main Street, Kalookan City"
                  },
                  "contactEmail": {
                    "type": "string",
                    "format": "email",
                    "example": "info@olpparish.org"
                  },
                  "contactPhone": {
                    "type": "string",
                    "example": "+639123456789"
                  },
                  "schedule": {
                    "type": "object",
                    "example": {
                      "sunday": "7:00 AM, 9:00 AM, 11:00 AM",
                      "weekdays": "6:00 AM"
                    }
                  },
                  "servicesOffered": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": ["baptism", "wedding", "confirmation", "mass-intention"]
                  },
                  "isActive": {
                    "type": "boolean",
                    "example": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parish updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Parish"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a parish (soft delete)",
        "tags": ["Parishes"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Only diocese_staff and diocese_admin can delete parishes",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Parish ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Parish deactivated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
