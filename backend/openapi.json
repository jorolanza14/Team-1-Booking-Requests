{
  "openapi": "3.0.0",
  "info": {
    "title": "Diocese of Kalookan - Sacramental Booking API",
    "version": "2.0.0",
    "description": "Backend API for the Diocese Sacramental Management System - Supporting Baptisms, Weddings, Confirmations, First Communion, Confession, Anointing of the Sick, Funeral Mass, and Mass Intentions"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "paths": {
    "/api/baptisms": {
      "get": {
        "summary": "Get all baptism bookings",
        "tags": ["Baptisms"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 10}},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["pending", "approved", "declined", "completed", "rescheduled"]}},
          {"name": "parishId", "in": "query", "schema": {"type": "integer"}},
          {"name": "startDate", "in": "query", "schema": {"type": "string", "format": "date"}},
          {"name": "endDate", "in": "query", "schema": {"type": "string", "format": "date"}}
        ],
        "responses": {
          "200": {
            "description": "List of baptism bookings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bookings": {"type": "array", "items": {"$ref": "#/components/schemas/BaptismBooking"}},
                    "pagination": {"$ref": "#/components/schemas/Pagination"}
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new baptism booking",
        "tags": ["Baptisms"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["parishId", "childFullName", "dateOfBirth", "fatherName", "motherName", "contactEmail", "contactPhone", "preferredDate", "preferredTimeSlot"],
                "properties": {
                  "parishId": {"type": "integer", "example": 1},
                  "childFullName": {"type": "string", "example": "Juan Dela Cruz"},
                  "dateOfBirth": {"type": "string", "format": "date", "example": "2025-01-15"},
                  "fatherName": {"type": "string", "example": "Jose Dela Cruz"},
                  "motherName": {"type": "string", "example": "Maria Dela Cruz"},
                  "contactEmail": {"type": "string", "format": "email", "example": "jose@example.com"},
                  "contactPhone": {"type": "string", "example": "09123456789"},
                  "preferredDate": {"type": "string", "format": "date", "example": "2025-03-15"},
                  "preferredTimeSlot": {"type": "string", "example": "09:00-10:00"},
                  "preferredPriest": {"type": "string", "example": "Fr. John Smith"},
                  "additionalNotes": {"type": "string", "example": "Special request"},
                  "godparents": {
                    "type": "array",
                    "items": {"$ref": "#/components/schemas/GodparentInput"}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Baptism booking created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {"type": "string"},
                    "booking": {"$ref": "#/components/schemas/BaptismBooking"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/baptisms/{id}": {
      "get": {
        "summary": "Get baptism booking by ID",
        "tags": ["Baptisms"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {
            "description": "Baptism booking details",
            "content": {
              "application/json": {
                "schema": {"type": "object", "properties": {"booking": {"$ref": "#/components/schemas/BaptismBooking"}}}
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update baptism booking",
        "tags": ["Baptisms"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"type": "object", "properties": {"status": {"type": "string"}, "additionalNotes": {"type": "string"}}}
            }
          }
        },
        "responses": {
          "200": {"description": "Baptism booking updated successfully"}
        }
      },
      "delete": {
        "summary": "Cancel baptism booking",
        "tags": ["Baptisms"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Baptism booking cancelled successfully"}
        }
      }
    },
    "/api/baptisms/{id}/status": {
      "patch": {
        "summary": "Approve/Decline baptism booking (Admin only)",
        "tags": ["Baptisms"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {"type": "string", "enum": ["approved", "declined"]},
                  "adminNotes": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Baptism booking status updated successfully"}
        }
      }
    },
    "/api/baptisms/available-slots": {
      "get": {
        "summary": "Get available time slots for baptism",
        "tags": ["Baptisms"],
        "parameters": [
          {"name": "parishId", "in": "query", "required": true, "schema": {"type": "integer"}},
          {"name": "date", "in": "query", "required": true, "schema": {"type": "string", "format": "date"}}
        ],
        "responses": {
          "200": {
            "description": "Available time slots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "timeSlots": {"type": "array", "items": {"$ref": "#/components/schemas/TimeSlot"}}
                  }
                }
              }
            }
          }
        }
      }
    },
