    "/api/parishes/by-service/{service}" : {
      "get": {
        "summary": "Get parishes by service offered",
        "tags": ["Parishes"],
        "description": "Public endpoint - no authentication required",
        "parameters": [
          {
            "name": "service",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Service to filter by (e.g., baptism, wedding, confirmation, mass-intention)"
