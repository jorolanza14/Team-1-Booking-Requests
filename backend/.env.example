# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diocese_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL_REQUIRED=true
DB_SSL_MODE=require

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-min-256-bits
JWT_EXPIRES_IN=15m
REFRESH_SECRET=your-super-secret-refresh-key-change-this-min-256-bits
REFRESH_EXPIRES_IN=7d

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=diocese.kalookan@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM="Diocese of Kalookan <diocese.kalookan@gmail.com>"

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads/documents
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# CORS Configuration (Flutter app origins)
ALLOWED_ORIGINS=http://localhost:8080,http://10.0.2.2:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=debug